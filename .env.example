# Copy this file to .env.local (gitignored) and fill in real values.
# No real secret ever belongs in this file or anywhere in the repo.

# Service ports for local development.
GATEWAY_PORT=4000
INTAKE_PORT=4001
EVIDENCE_PORT=4002
CLAIMS_PORT=4003
GRAPH_PORT=4004
NOTIFY_PORT=4005

# Internal service base URLs (the gateway calls these).
INTAKE_URL=http://localhost:4001
EVIDENCE_URL=http://localhost:4002
CLAIMS_URL=http://localhost:4003
GRAPH_URL=http://localhost:4004
NOTIFY_URL=http://localhost:4005

# Frontend to gateway.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000

# Logging: debug | info | warn | error.
LOG_LEVEL=info

# Demo mode uses deterministic mock adapters and seeded data, and never calls a
# live external provider. Keep this true until real providers are wired.
DEMO_MODE=true

# Required for cockpit queue, detail, and decision routes when DEMO_MODE=false.
# Use a real secret from the deployment secret manager, never this placeholder.
ADJUSTER_TOKEN=replace-with-a-secret-at-least-16-characters


# Placeholders for the real providers wired later. Leave blank in demo mode.
SPEECH_API_KEY=
VISION_API_KEY=
LLM_API_KEY=
SMS_API_KEY=
