{
  "name": "@sinistria/evidence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multimodal intelligence: damage localization, OCR, consistency, completeness.",
  "exports": {
    "./core": {
      "types": "./src/core/process.ts",
      "default": "./src/core/process.ts"
    },
    "./seed-ref": {
      "types": "./src/adapters/seed-ref.ts",
      "default": "./src/adapters/seed-ref.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sinistria/config": "workspace:*",
    "@sinistria/contracts": "workspace:*",
    "@sinistria/logger": "workspace:*",
    "@sinistria/service-kit": "workspace:*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
