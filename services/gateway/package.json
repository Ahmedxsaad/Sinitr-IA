{
  "name": "@sinistria/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API gateway: single entry point, claim orchestration, SQLite-backed claim store.",
  "exports": {
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@sinistria/config": "workspace:*",
    "@sinistria/contracts": "workspace:*",
    "@sinistria/logger": "workspace:*",
    "@sinistria/service-kit": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
