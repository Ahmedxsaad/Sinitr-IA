{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Modern output that Node 20+ and bundlers both understand.
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],

    // Strictness is on everywhere. External input is still validated at
    // runtime with the shared Zod schemas from @sinistria/contracts.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    // Quality signals that keep the tree clean.
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    // Interop and ergonomics.
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  }
}
